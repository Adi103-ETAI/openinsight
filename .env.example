# ==========================================
# OpenInsight — Secrets Only
# ==========================================
# Non-secret defaults are in config.base.json
# Production overrides are in config.production.json
# Kaggle/Colab overrides are in config.kaggle.json
#
# Copy this file to .env and fill in your secrets:
#   cp .env.example .env
# ==========================================

# ── LLM ──────────────────────────────────
NVIDIA_NIM_API_KEY=

# ── MongoDB (connection string contains credentials) ──
MONGODB_URL=

# ── Vector DB (Zilliz Cloud credentials) ──
VECTOR_URI=
VECTOR_TOKEN=

# ── HuggingFace ──────────────────────────
HF_API_TOKEN=

# ── Cohere ───────────────────────────────
COHERE_API_KEY=

# ── NCBI / PubMed ────────────────────────
NCBI_API_KEY=
NCBI_EMAIL=

# ── Environment ──────────────────────────
# Options: development | production | kaggle
APP_ENV=development
