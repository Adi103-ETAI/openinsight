# LLM
NVIDIA_NIM_API_KEY=your_nim_api_key_here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# MongoDB (use MongoDB Atlas for production: mongodb+srv://user:pass@cluster.mongodb.net/openinsight)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=openinsight

# Qdrant (for Qdrant Cloud set QDRANT_API_KEY; leave empty for local Docker)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=openinsight_chunks

# Redis
REDIS_URL=redis://localhost:6379

# PubMed / NCBI (register at https://www.ncbi.nlm.nih.gov/account/ for a free API key)
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_email@example.com

# Embeddings model
EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO

# Ingestion pipeline
INGESTION_BATCH_SIZE=50
INGESTION_MAX_RETRIES=3
INGESTION_RETRY_DELAY=2.0
QUALITY_SCORE_THRESHOLD=0.3
DEDUP_TITLE_SIMILARITY=0.9

# Scheduler — cron expressions (minute hour day month day_of_week)
SCHEDULER_PUBMED_CRON=0 2 * * 0
SCHEDULER_WHO_CRON=0 3 1 * *
SCHEDULER_CDC_CRON=0 4 1 * *
SCHEDULER_COCHRANE_CRON=0 5 1 * *

# App
APP_ENV=development
LOG_LEVEL=DEBUG
